# HIVEE backend environment example.
#
# Copy this file to backend/.env when you need local customization:
#
#   copy .env.example .env      # Windows PowerShell/cmd
#   cp .env.example .env        # macOS/Linux
#
# Do not commit backend/.env. Keep real API keys only in local/prod env vars.

# Django
DJANGO_SECRET_KEY=django-insecure-hivee-local-dev-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5200,http://127.0.0.1:5200
DJANGO_AUTH_COOKIE_NAME=hivee_token

# OpenAI agent
# Required only for real AI responses, image analysis and audio transcription.
OPENAI_API_KEY=

# Optional RAG with Supabase. Leave disabled unless you have the Supabase
# vector store configured.
RAG_ENABLED=False
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional WhatsApp integration through WAHA.
WHATSAPP_ENABLED=False
WAHA_API_URL=
WAHA_SESSION=hivee
WAHA_API_KEY=

# Optional tuning for message buffering.
AGENT_BUFFER_WHATSAPP_SECONDS=8
AGENT_BUFFER_SITE_SECONDS=1.5
