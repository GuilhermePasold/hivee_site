# Modelo de variáveis de ambiente do backend HIVEE.
#
# Este arquivo é OPCIONAL: o projeto roda sem .env, pois settings.py tem
# fallbacks seguros para desenvolvimento local. Para personalizar, copie este
# arquivo para ".env" (na pasta backend/) e ajuste os valores.
#
#   cp .env.example .env        # Linux/Mac
#   copy .env.example .env      # Windows

# Chave secreta do Django. Em produção, gere uma única e mantenha em segredo.
DJANGO_SECRET_KEY=django-insecure-hivee-local-dev-change-me

# Modo debug (True em desenvolvimento, False em produção).
DJANGO_DEBUG=True

# Hosts permitidos (separados por vírgula). Sem curinga "*".
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Origens confiáveis para CSRF (front-end Vite).
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5200,http://127.0.0.1:5200

# Nome do cookie httpOnly que transporta o token de autenticação.
DJANGO_AUTH_COOKIE_NAME=hivee_token
